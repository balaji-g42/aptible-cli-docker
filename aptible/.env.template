# =================================================
# Aptible Tunnel Service Configuration
# =================================================

# Token file path
TOKEN_FILE="/root/.aptible/tokens.json"

# PostgreSQL Tunnel 1 Configuration
PG1_APP="postgresql-db"
PG1_INTERNAL_PORT=54321
PG1_PUBLIC_PORT=54321
PG1_LOG="/var/log/postgresql1-tunnel.log"

# PostgreSQL Tunnel 2 Configuration (optional)
# Uncomment and configure if you need a second PostgreSQL tunnel
# PG2_APP="postgresql-db2"
# PG2_INTERNAL_PORT=54322
# PG2_PUBLIC_PORT=61322
# PG2_LOG="/var/log/postgresql2-tunnel.log"

# Redis Tunnel Configuration
REDIS_APP="redis-db"
REDIS_INTERNAL_PORT=51596
REDIS_PUBLIC_PORT=51597
REDIS_LOG="/var/log/redis-tunnel.log"

# Redis TLS Configuration
# Default SANs: localhost, 127.0.0.1
# Add extra domains separated by commas (e.g., "example.com,api.example.com")
REDIS_TLS_EXTRA_DOMAINS=""

# Terminal UI Configuration
UI_LOG="/var/log/terminal-ui.log"
UI_PORT=3000

# Home directories
HOME="/root"
APTIBLE_HOME="/root/.aptible"